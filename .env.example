# Repo kökünde .env oluşturun:  cp .env.example .env
# Gerçek sır: .env dosyasını repoya eklemeyin.
# Pi kurulum: sudo ./setup.sh (JWT ve mDNS otomatik)

PORT=8080
VOICE_RTP_PORT=5004

# HTTP + WS dinleme adresi. LAN’dan telefon erişimi için 0.0.0.0
HTTP_LISTEN_HOST=0.0.0.0

# Zorunlu: JWT imzalama (min. 32 karakter). Pi setup: openssl rand -base64 48
JWT_SECRET=change-me-long-random-string-REPLACE-WITH-SECURE-VALUE

# mDNS host adı (kurulum: aksiyonsoft-radio-xxxxxx, .local eklenmez)
# MDNS_HOSTNAME=aksiyonsoft-radio-a1b2c3

DATABASE_PATH=./data/radio.db

# Köken listesi (tam URL). Pi setup otomatik: http://<MDNS_HOSTNAME>.local:8080
CORS_ORIGINS=*

MESSAGE_MAX_LENGTH=500
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Ses / RTP (isteğe bağlı) ─────────────────────────────────────────────
# VOICE_RTP_LOG_REGISTER=1
# VOICE_RTP_METRICS=1

# ─── Uzak dağıtım (isteğe bağlı, scripts/publish-server.cjs) ─────────────
# DEPLOY_SSH_TARGET=user@host
# DEPLOY_REMOTE_PATH=/home/user/radio-server
# DEPLOY_REMOTE_COMMAND=cd /home/user/radio-server && npm ci --omit=dev && sudo systemctl restart radio-server
