# ─────────────────────────────────────────────────────────────────────────────
# radio-server/.env
#
# Kurulum:
#   cp .env.example .env
#   # Geliştirme: JWT_SECRET ve CORS_ORIGINS'i düzenleyin
#   npm run dev
#
# Raspberry Pi (production):
#   sudo ./setup.sh
#   → scripts/02-env.sh otomatik yazar: JWT_SECRET, MDNS_HOSTNAME, CORS_ORIGINS,
#     NODE_ENV=production, PORT, HTTP_LISTEN_HOST, VOICE_RTP_PORT, DATABASE_PATH,
#     MESSAGE_MAX_LENGTH, RATE_LIMIT_* değerleri.
#
# Gerçek .env dosyasını repoya eklemeyin.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Çekirdek ───────────────────────────────────────────────────────────────

# HTTP + WebSocket portu
PORT=8080

# UDP ses (RTP) portu
VOICE_RTP_PORT=5004

# Dinleme adresi. LAN'dan telefon erişimi için 0.0.0.0; yalnızca localhost için 127.0.0.1
HTTP_LISTEN_HOST=0.0.0.0

# production → CORS_ORIGINS zorunlu (wildcard * kabul edilmez, sunucu başlamaz)
# development → CORS_ORIGINS=* kullanılabilir
NODE_ENV=development


# ─── Kimlik / güvenlik ───────────────────────────────────────────────────────

# Zorunlu: JWT imzalama (min. 32 karakter). Pi setup: openssl rand -base64 48
JWT_SECRET=change-me-long-random-string-REPLACE-WITH-SECURE-VALUE


# ─── Veritabanı ─────────────────────────────────────────────────────────────

DATABASE_PATH=./data/radio.db


# ─── mDNS / CORS ──────────────────────────────────────────────────────────────

# mDNS host adı (.local eklenmez). Pi setup: aksiyonsoft-radio-xxxxxx
# Boş bırakılırsa /health ve /status yanıtında mdnsHostname olmaz.
MDNS_HOSTNAME=

# İzin verilen kökenler (virgülle, tam URL). Pi setup otomatik:
#   http://<MDNS_HOSTNAME>.local:<PORT>
# Production'da * kullanılamaz.
CORS_ORIGINS=*


# ─── Sürüm raporlama (/health, /status) ───────────────────────────────────────

# /health ve /status içindeki version alanı. Tanımlı değilse "dev" görünür.
APP_VERSION=1.0.0

# Deploy edilen git commit (kısa SHA). Tanımlı değilse "unknown" görünür.
# Örnek üretim: APP_GIT_SHA=$(git rev-parse --short HEAD)
APP_GIT_SHA=


# ─── API sınırları ───────────────────────────────────────────────────────────

# Sohbet mesajı üst karakter sınırı
MESSAGE_MAX_LENGTH=500

# Genel rate limit penceresi (ms)
RATE_LIMIT_WINDOW_MS=60000

# Pencere başına maksimum istek
RATE_LIMIT_MAX_REQUESTS=100


# ─── Ses / RTP ────────────────────────────────────────────────────────────────

# Konuşmacı kilidi süresi (ms). Süre dolunca kilit düşer.
VOICE_LOCK_TTL_MS=60000

# RTP paketi geldikçe kilidi yenileme throttle (ms)
VOICE_LOCK_RTP_RENEW_MS=4000

# Konuşmacı RTP paketi gelmezse otomatik kilidi bırakma (ms, varsayılan 5 dk)
VOICE_NO_PACKET_SPEAKER_TIMEOUT_MS=300000

# RTP endpoint kayıtlarını konsola yaz (1=açık)
# VOICE_RTP_LOG_REGISTER=1

# /health içinde voiceRtpMetrics döndür (1=açık, yük testi için)
# VOICE_RTP_METRICS=1

# Bilinmeyen RTP kaynaklarına katı red (1=açık)
# VOICE_RTP_STRICT=1


# ─── Teşhis / geliştirme ──────────────────────────────────────────────────────

# 404 API isteklerini logla (1=açık)
# API_ROUTE_LOG_404=1


# ─── Uzak dağıtım (scripts/publish-server.cjs) ───────────────────────────────

# DEPLOY_SSH_TARGET=user@host
# DEPLOY_REMOTE_PATH=/home/user/radio-server
# DEPLOY_REMOTE_COMMAND=cd /home/user/radio-server && npm ci --omit=dev && sudo systemctl restart radio-server


# ─── Test scriptleri (sunucu okumaz; scripts/voice-smoke.cjs) ─────────────────

# BASE_URL=http://127.0.0.1:8080
# ADMIN_TOKEN=
